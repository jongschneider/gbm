              "32x32": "https://secure.gravatar.com/avatar/73d47f3fad801d4c0241d7c701c08850?d=https%3A%2F%2Favatar-management--avatars.us-west-2.prod.public.atl-paas.net%2Finitials%2FJO-4.png"
            },
            "displayName": "Jeff Overton",
            "active": true,
            "timeZone": "America/Chicago",
            "accountType": "atlassian"
          },
          "body": {
            "type": "doc",
            "version": 1,
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "so I created a conversation with subject of \"A\" then changed it to \"B\", \"D\" and finally \"D\".  What I see is"
                  }
                ]
              },
              {
                "type": "orderedList",
                "attrs": {
                  "order": 1
                },
                "content": [
                  {
                    "type": "listItem",
                    "content": [
                      {
                        "type": "paragraph",
                        "content": [
                          {
                            "type": "text",
                            "text": "getAllMessages has message with Subject of D"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "listItem",
                    "content": [
                      {
                        "type": "paragraph",
                        "content": [
                          {
                            "type": "text",
                            "text": "getAllRetainedMessages has message with Subject of C"
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Theta Lake did not report the conversation rename and the record name, which is based on the conversation name, did not change either. I’ve opened "
                  },
                  {
                    "type": "inlineCard",
                    "attrs": {
                      "url": "https://thetalake.atlassian.net/browse/EPIC-3089"
                    }
                  },
                  {
                    "type": "text",
                    "text": " for this and put it on the list for H release (Early April 2026) . "
                  }
                ]
              }
            ]
          },
